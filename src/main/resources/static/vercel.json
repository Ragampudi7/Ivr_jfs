{
  "rewrites": [
    {
      "source": "/auth/(.*)",
      "destination": "https://ivr-health-reminder.onrender.com/auth/$1"
    },
    {
      "source": "/users/(.*)",
      "destination": "https://ivr-health-reminder.onrender.com/users/$1"
    },
    {
      "source": "/reminders/(.*)",
      "destination": "https://ivr-health-reminder.onrender.com/reminders/$1"
    },
    {
      "source": "/call/(.*)",
      "destination": "https://ivr-health-reminder.onrender.com/call/$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://ivr-health-reminder.onrender.com/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
