# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# -----------------------------------------------------------------------------
# Paste your AIVEN or local MySQL connection details here.
# For Aiven MySQL, your connection string should look like:
# jdbc:mysql://avnadmin:pass@host:port/defaultdb?sslMode=REQUIRED
#
# So separate it out like this:
DB_URL=jdbc:mysql://YOUR_AIVEN_HOST:YOUR_AIVEN_PORT/defaultdb?sslMode=REQUIRED
DB_USERNAME=avnadmin
DB_PASSWORD=YOUR_AIVEN_PASSWORD

# Note: On Render, you don't need this .env file. You can simply add 
# DB_URL, DB_USERNAME, and DB_PASSWORD directly in Render's Environment Variables!
